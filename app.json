{
  "expo": {
    "name": "NutriTrack",
    "slug": "nutritrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nutritrack",
    "userInterfaceStyle": "light",
    "ios": { "supportsTablet": false },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nutritrack.app"
    },
    "plugins": ["expo-router"]
  }
}
